{
  "name": "knewbeing-blogs",
  "type": "module",
  "version": "1.0.1",
  "engines": {
    "node": ">=22.16.0 <25"
  },
  "author": {
    "name": "知在",
    "email": "zz@dmsrs.org",
    "url": "https://www.dmsrs.org"
  },
  "license": "MIT",
  "keywords": [
    "vitepress",
    "knewbeing",
    "markdown",
    "knewbeing-integration",
    "obsidian",
    "knowledge-base",
    "vitepress-doc"
  ],
  "scripts": {
    "workspace:install": "pnpm install",
    "workspace:dev": "pnpm -r --filter \"@knewbeing/*\" --parallel --if-present run dev",
    "workspace:build": "pnpm -r --filter \"@knewbeing/*\" --if-present run build",
    "workspace:publish": "pnpm -r --filter \"@knewbeing/*\" --if-present publish --access public --no-git-checks",
    "graph:matrix": "tsx scripts/generate-gravity-matrix.ts",
    "predev": "pnpm run workspace:dev",
    "dev": "vitepress dev",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 vitepress build",
    "prebuild": "pnpm run workspace:build && pnpm run graph:matrix",
    "serve": "vitepress serve",
    "build:test": "pnpm run workspace:build && pnpm run graph:matrix && tsx scripts/test-build.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@hedgedoc/markdown-it-plugins": "^2.1.4",
    "@iconify-json/carbon": "^1.2.23",
    "@iconify-json/eos-icons": "^1.2.4",
    "@iconify-json/ic": "^1.2.4",
    "@iconify-json/icon-park-outline": "^1.2.4",
    "@iconify-json/octicon": "^1.2.29",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@knewbeing/vitepress-plugin-autosidebar-toc": "workspace:*",
    "@knewbeing/vitepress-plugin-graph-view": "workspace:*",
    "@knewbeing/vitepress-plugin-index": "workspace:*",
    "@knewbeing/vitepress-plugin-meta": "workspace:*",
    "@knewbeing/vitepress-plugin-nolebase": "workspace:*",
    "@knewbeing/vitepress-plugin-page-properties": "workspace:*",
    "@knewbeing/vitepress-plugin-remove-sidebar": "workspace:*",
    "@netlify/functions": "^5.3.0",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.24",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-footnote": "^3.0.4",
    "@typescript-eslint/parser": "^8.62.1",
    "@typescript-eslint/rule-tester": "^8.62.1",
    "@unocss/eslint-config": "^66.7.4",
    "@unocss/reset": "^66.7.4",
    "@vueuse/core": "^14.3.0",
    "@vueuse/shared": "^14.3.0",
    "concat-map": "^0.0.2",
    "emoji-regex": "^10.6.0",
    "eslint": "^10.6.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.6",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "less": "^4.6.7",
    "lodash": "^4.18.1",
    "markdown-it": "^14.3.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-mathjax3": "5.2.0",
    "mermaid": "^11.16.0",
    "oxc-minify": "^0.138.0",
    "pinyin-pro": "^3.28.1",
    "playwright": "^1.61.1",
    "sharp": "^0.35.3",
    "simple-git": "^3.36.0",
    "tsup": "^8.5.1",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "unocss": "^66.7.4",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "uuid": "^14.0.1",
    "vite": "8.1.2",
    "vite-plugin-inspect": "^11.4.1",
    "vitepress": "2.0.0-alpha.15",
    "vue": "^3.5.39"
  }
}
