{
  "name": "nolebase",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.16.0 <25"
  },
  "packageManager": "pnpm@10.33.0",
  "author": {
    "name": "知在",
    "email": "zz@dmsrs.org",
    "url": "https://www.dmsrs.org"
  },
  "license": "MIT",
  "keywords": [
    "vitepress",
    "nolebase",
    "markdown",
    "nolebase-integration",
    "obsidian",
    "knowledge-base",
    "vitepress-doc"
  ],
  "scripts": {

    "build:referenced-packages": "pnpm --filter @knewbeing/utils build && pnpm --filter @knewbeing/vitepress-plugin-autosidebar-toc build",
    "dev:referenced-packages": "pnpm -r --parallel --stream --filter @knewbeing/utils --filter @knewbeing/vitepress-plugin-autosidebar-toc run dev",
    "predev": "pnpm run build:referenced-packages",
    "prebuild": "pnpm run build:referenced-packages",
    "preserve": "pnpm run build:referenced-packages",
    "dev": "vitepress dev",
    "build": "vitepress build",
    "serve": "vitepress serve",
    "build:test": "pnpm run build:referenced-packages && tsx scripts/test-build.ts"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.1.0",
    "@hedgedoc/markdown-it-plugins": "^2.1.4",
    "@iconify-json/carbon": "^1.2.20",
    "@iconify-json/eos-icons": "^1.2.4",
    "@iconify-json/ic": "^1.2.4",
    "@iconify-json/icon-park-outline": "^1.2.4",
    "@iconify-json/octicon": "^1.2.22",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@knewbeing/vitepress-plugin-autosidebar-toc": "workspace:*",
    "@netlify/functions": "^5.1.5",
    "@nolebase/integrations": "2.18.2",
    "@nolebase/markdown-it-bi-directional-links": "^2.18.2",
    "@nolebase/markdown-it-unlazy-img": "^2.18.2",
    "@nolebase/vitepress-plugin-enhanced-mark": "^2.18.2",
    "@nolebase/vitepress-plugin-enhanced-readabilities": "^2.18.2",
    "@nolebase/vitepress-plugin-git-changelog": "^2.18.2",
    "@nolebase/vitepress-plugin-highlight-targeted-heading": "^2.18.2",
    "@nolebase/vitepress-plugin-index": "^2.18.2",
    "@nolebase/vitepress-plugin-inline-link-preview": "^2.18.2",
    "@nolebase/vitepress-plugin-meta": "^2.18.2",
    "@nolebase/vitepress-plugin-og-image": "^2.18.2",
    "@nolebase/vitepress-plugin-page-properties": "^2.18.2",
    "@nolebase/vitepress-plugin-sidebar": "^2.18.2",
    "@nolebase/vitepress-plugin-thumbnail-hash": "^2.18.2",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.24",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/node-fetch": "^2.6.13",
    "@typescript-eslint/parser": "^8.58.1",
    "@typescript-eslint/rule-tester": "^8.58.1",
    "@unocss/eslint-config": "^66.6.8",
    "@unocss/reset": "^66.6.8",
    "@vueuse/core": "^14.2.1",
    "@vueuse/shared": "^14.2.1",
    "concat-map": "^0.0.2",
    "emoji-regex": "^10.6.0",
    "eslint": "^10.2.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.4",
    "gray-matter": "^4.0.3",
    "less": "^4.6.4",
    "lodash": "^4.18.1",
    "markdown-it": "^14.1.1",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-mathjax3": "4.3.2",
    "mermaid": "^11.14.0",
    "node-fetch": "^3.3.2",
    "pinyin-pro": "^3.28.0",
    "sharp": "^0.34.5",
    "simple-git": "^3.35.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "unocss": "^66.6.8",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-vue-components": "^30.0.0",
    "uuid": "^13.0.0",
    "vite": "^7.3.2",
    "vite-plugin-inspect": "^11.3.3",
    "vitepress": "2.0.0-alpha.15",
    "vue": "^3.5.32"
  },
  "pnpm": {
    "overrides": {
      "@typescript-eslint/parser": "^8.58.1",
      "@typescript-eslint/project-service": "^8.58.1",
      "@typescript-eslint/rule-tester": "^8.58.1",
      "@typescript-eslint/tsconfig-utils": "^8.58.1",
      "@typescript-eslint/typescript-estree": "^8.58.1",
      "@typescript-eslint/utils": "^8.58.1",
      "ajv": "8.18.0",
      "axios": ">=1.13.5",
      "flatted": ">=3.4.2",
      "balanced-match": "4.0.4",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "rollup": ">=4.59.0"
    }
  }
