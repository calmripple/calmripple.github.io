{
  "name": "@knewbeing/vitepress-plugin-autosidebar-toc",
  "version": "0.0.0",
  "description": "Auto-generate sidebar, navigation, and blog components for VitePress. Provides Markdown scanning, metadata extraction, and ready-to-use components (BlogHome, AutoToc, SidebarArticleList).",
  "keywords": [
    "vitepress",
    "sidebar",
    "navigation",
    "blog",
    "markdown",
    "documentation",
    "vite-plugin",
    "vue3",
    "typescript"
  ],
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "client/AutoToc.vue",
    "client/BlogHome.vue",
    "client/SidebarArticleList.vue",
    "client/TagsCloud.vue",
    "client/useTocEntries.ts",
    "client/useBlogHome.ts",
    "client/useIndexTagsStore.ts",
    "client/useTocSidebarConfig.ts",
    "client/style.css",
    "globals.d.ts"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@knewbeing/utils": "workspace:*",
    "sanitize-html": "^2.17.2"
  },
  "devDependencies": {
    "tsup": "^8.5.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client/AutoToc.vue": "./client/AutoToc.vue",
    "./client/BlogHome.vue": "./client/BlogHome.vue",
    "./client/SidebarArticleList.vue": "./client/SidebarArticleList.vue",
    "./client/useTocEntries": "./client/useTocEntries.ts",
    "./client/useBlogHome": "./client/useBlogHome.ts",
    "./client/useIndexTagsStore": "./client/useIndexTagsStore.ts",
    "./client/useTocSidebarConfig": "./client/useTocSidebarConfig.ts",
    "./client/TagsCloud.vue": "./client/TagsCloud.vue",
    "./client/style.css": "./client/style.css"
  }
}
