{
  "name": "@knewbeing/vitepress-plugin-autosidebar-toc",
  "version": "1.1.1",
  "description": "Auto-generate sidebar, navigation, and blog components for VitePress. Provides Markdown scanning, metadata extraction, and ready-to-use components (AutoToc, SidebarArticleList).",
  "keywords": [
    "vitepress",
    "sidebar",
    "navigation",
    "blog",
    "markdown",
    "documentation",
    "vite-plugin",
    "vue3",
    "typescript"
  ],
  "license": "MIT",
  "author": {
    "name": "知在",
    "email": "zz@dmsrs.org",
    "url": "https://www.dmsrs.org"
  },
  "homepage": "https://github.com/VitepressAwesome/vitepress-plugin-blogs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VitepressAwesome/vitepress-plugin-blogs.git",
    "directory": "packages/vitepress-plugin-autosidebar-toc"
  },
  "bugs": {
    "url": "https://github.com/VitepressAwesome/vitepress-plugin-blogs/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "globals.d.ts",
    "package.json"
  ],
  "scripts": {
    "stub": "unbuild --stub",
    "dev": "unbuild --stub",
    "build": "unbuild",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "sanitize-html": "^2.17.5",
    "thumbhash": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/sanitize-html": "^2.16.1",
    "typescript": "5.9.3",
    "unbuild": "^3.6.1",
    "unplugin-vue-components": "^32.1.0",
    "vite": "8.1.2",
    "vitepress": "2.0.0-alpha.15",
    "vue": "^3.5.39",
    "vue-tsc": "^3.3.6"
  },
  "peerDependencies": {
    "sharp": "^0.35.3",
    "vite": "8.1.2",
    "vitepress": "2.0.0-alpha.15",
    "vue": "^3.5.39"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./client/AutoToc.vue": "./dist/client/AutoToc.vue",
    "./client/SidebarArticleList.vue": "./dist/client/SidebarArticleList.vue",
    "./client/useTocEntries": {
      "types": "./dist/client/useTocEntries.d.ts",
      "import": {
        "development": "./client/useTocEntries.ts",
        "default": "./dist/client/useTocEntries.mjs"
      },
      "require": "./dist/client/useTocEntries.js"
    },
    "./client/useBlogHome": {
      "types": "./dist/client/useBlogHome.d.ts",
      "import": {
        "development": "./client/useBlogHome.ts",
        "default": "./dist/client/useBlogHome.mjs"
      },
      "require": "./dist/client/useBlogHome.js"
    },
    "./client/useIndexTagsStore": {
      "types": "./dist/client/useIndexTagsStore.d.ts",
      "import": {
        "development": "./client/useIndexTagsStore.ts",
        "default": "./dist/client/useIndexTagsStore.mjs"
      },
      "require": "./dist/client/useIndexTagsStore.js"
    },
    "./client/useTocSidebarConfig": {
      "types": "./dist/client/useTocSidebarConfig.d.ts",
      "import": {
        "development": "./client/useTocSidebarConfig.ts",
        "default": "./dist/client/useTocSidebarConfig.mjs"
      },
      "require": "./dist/client/useTocSidebarConfig.js"
    },
    "./client/TagsCloud.vue": "./dist/client/TagsCloud.vue",
    "./client/ThumbHashImage.vue": "./dist/client/ThumbHashImage.vue",
    "./client/style.css": "./dist/client/style.css"
  }
}
