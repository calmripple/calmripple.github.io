{
  "name": "@knewbeing/vitepress-plugin-graph-view",
  "version": "1.1.1",
  "description": "Knowledge graph view for VitePress markdown content.",
  "license": "MIT",
  "author": {
    "name": "知在",
    "email": "zz@dmsrs.org",
    "url": "https://www.dmsrs.org"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/VitepressAwesome/vitepress-plugin-graph-view.git",
    "directory": "packages/vitepress-plugin-graph-view"
  },
  "scripts": {
    "stub": "unbuild --stub",
    "dev": "unbuild --stub",
    "build": "unbuild",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run src/vitepress/graph.test.ts src/client/loaders/gravityMatrix.test.ts"
  },
  "exports": {
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": {
        "development": "./src/client/index.ts",
        "default": "./dist/client/index.mjs"
      },
      "require": "./dist/client/index.js"
    },
    "./client/style.css": "./dist/client/style.css",
    "./locales": {
      "types": "./dist/locales/index.d.ts",
      "import": {
        "development": "./src/locales/index.ts",
        "default": "./dist/locales/index.mjs"
      },
      "require": "./dist/locales/index.cjs"
    },
    "./vitepress": {
      "types": "./dist/vitepress/index.d.ts",
      "import": {
        "development": "./src/vitepress/index.ts",
        "default": "./dist/vitepress/index.mjs"
      },
      "require": "./dist/vitepress/index.cjs"
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@rollup/plugin-yaml": "^5.0.0",
    "@types/three": "^0.185.0",
    "typescript": "5.9.3",
    "unbuild": "^3.6.1",
    "vitest": "^4.1.9",
    "vue-sfc-transformer": "^0.1.17",
    "vue-tsc": "^3.3.6"
  },
  "peerDependencies": {
    "vitepress": "2.0.0-alpha.15",
    "vue": "^3.5.39"
  },
  "dependencies": {
    "3d-force-graph": "^1.80.0",
    "@knewbeing/ui": "workspace:*",
    "babylonjs": "9.14.0",
    "defu": "^6.1.7",
    "echarts": "^6.1.0",
    "echarts-gl": "^2.1.0",
    "gray-matter": "^4.0.3",
    "three-spritetext": "^1.10.0",
    "tinyglobby": "^0.2.17"
  }
}
