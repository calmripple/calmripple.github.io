{
  "name": "@knewbeing/vitepress-plugin-nolebase",
  "version": "1.0.1",
  "description": "Vendored nolebase integrations for VitePress -?enhanced-readabilities, git-changelog, inline-link-preview, highlight-targeted-heading, index, and more. .",
  "keywords": ["vitepress", "nolebase", "enhanced-readabilities", "git-changelog", "inline-link-preview", "vite-plugin", "typescript"],
  "license": "MIT",
  "author": { "name": "知在", "email": "zz@dmsrs.org", "url": "https://www.dmsrs.org" },
  "type": "module",
  "sideEffects": ["**/*.css"],
  "scripts": {
    "stub": "unbuild --stub",
    "dev": "unbuild --stub",
    "build": "unbuild",
    "typecheck": "vue-tsc --noEmit"
  },
  "exports": {
    "./vitepress/client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.mjs",
      "require": "./dist/client/index.js"
    },
    "./vitepress/vite": {
      "types": "./dist/vitepress/vite/index.d.ts",
      "import": "./dist/vitepress/vite/index.mjs",
      "require": "./dist/vitepress/vite/index.cjs"
    },
    "./vitepress/markdown-it": {
      "types": "./dist/vitepress/markdown-it/index.d.ts",
      "import": "./dist/vitepress/markdown-it/index.mjs",
      "require": "./dist/vitepress/markdown-it/index.cjs"
    }
  },
  "files": ["dist", "package.json"],
  "publishConfig": { "access": "public", "registry": "https://registry.npmjs.org/" },
  "devDependencies": {
    "typescript": "catalog:",
    "unbuild": "catalog:",
    "vue-tsc": "catalog:"
  },
  "peerDependencies": {
    "vite": "catalog:",
    "vitepress": "catalog:",
    "vue": "catalog:"
  },
  "dependencies": {
    "defu": "catalog:",
    "@knewbeing/ui": "workspace:*",
    "@knewbeing/markdown-it-element-transform": "workspace:*",
    "@knewbeing/markdown-it-bi-directional-links": "workspace:*",
    "@knewbeing/markdown-it-unlazy-img": "workspace:*",
    "@knewbeing/vitepress-plugin-enhanced-mark": "workspace:*",
    "@knewbeing/vitepress-plugin-enhanced-readabilities": "workspace:*",
    "@knewbeing/vitepress-plugin-git-changelog": "workspace:*",
    "@knewbeing/vitepress-plugin-highlight-targeted-heading": "workspace:*",
    "@knewbeing/vitepress-plugin-index": "workspace:*",
    "@knewbeing/vitepress-plugin-inline-link-preview": "workspace:*",
    "@knewbeing/vitepress-plugin-meta": "workspace:*"
  }
}
