#!/bin/sh
# If branch name is invalid, auto-rename it then abort so user re-runs push.
# Valid: yyyy/MM/dd/HHmm-<description>  e.g. 2026/04/13/1630-feat-nav-active

branch=$(git symbolic-ref --short HEAD 2>/dev/null)

# Allow detached HEAD / main / master
if [ -z "$branch" ] || [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
  exit 0
fi

# Already valid?
if echo "$branch" | grep -qE '^[0-9]{4}/(0[1-9]|1[0-2])/(0[1-9]|[12][0-9]|3[01])/([01][0-9]|2[0-3])[0-5][0-9]-'; then
  exit 0
fi

# Generate datetime prefix
prefix=$(date +'%Y/%m/%d/%H%M')

# Sanitize original name: keep alphanumeric / dots / hyphens
clean=$(echo "$branch" | sed 's/[^a-zA-Z0-9._-]/-/g' | sed 's/-\{2,\}/-/g' | sed 's/^-//;s/-$//')

new_branch="${prefix}-${clean}"

echo ""
echo "⚠  分支名不符合规范，自动重命名..."
echo "   原分支: $branch"
echo "   新分支: $new_branch"
echo ""

git branch -m "$new_branch"

echo "✓  重命名成功，请重新执行 push："
echo "   git push origin $new_branch"
echo ""
exit 1
